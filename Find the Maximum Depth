import xml.etree.ElementTree as etree

maxdepth = 0

def depth(elem, level):
    global maxdepth
    
    if level > maxdepth:
        maxdepth = level
    
    for child in elem:
        depth(child, level + 1)

if __name__ == '__main__':
    n = int(input())
    xml = ""
    
    for _ in range(n):
        xml += input()
    
    tree = etree.ElementTree(etree.fromstring(xml))
    root = tree.getroot()
    
    depth(root, 0)
    print(maxdepth)
