import re

n = int(input())

for _ in range(n):
    card = input()
    pattern = r'^[456]\d{3}(-?\d{4}){3}$'
    
    if re.match(pattern, card):
        clean_card = card.replace('-', '')
        if re.search(r'(\d)\1{3,}', clean_card):
            print("Invalid")
        else:
            print("Valid")
    else:
        print("Invalid")
