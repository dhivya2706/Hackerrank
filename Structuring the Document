
struct document get_document(char* text) {
     struct document doc;
    doc.data = malloc(MAX_PARAGRAPHS * sizeof(struct paragraph));
    doc.paragraph_count = 0;

    char *p_save;
    char *paragraph = strtok_r(text, "\n", &p_save);

    while (paragraph) {
        struct paragraph para;
        para.data = malloc(MAX_CHARACTERS * sizeof(struct sentence));
        para.sentence_count = 0;

        char *s_save;
        char *sentence = strtok_r(paragraph, ".", &s_save);

        while (sentence) {
            struct sentence sen;
            sen.data = malloc(MAX_CHARACTERS * sizeof(struct word));
            sen.word_count = 0;

            char *w_save;
            char *word = strtok_r(sentence, " ", &w_save);

            while (word) {
                sen.data[sen.word_count].data = malloc(strlen(word) + 1);
                strcpy(sen.data[sen.word_count].data, word);
                sen.word_count++;
                word = strtok_r(NULL, " ", &w_save);
            }

            para.data[para.sentence_count++] = sen;
            sentence = strtok_r(NULL, ".", &s_save);
        }

        doc.data[doc.paragraph_count++] = para;
        paragraph = strtok_r(NULL, "\n", &p_save);
    }

    return doc;
}

struct paragraph kth_paragraph(struct document Doc, int k) {
    return Doc.data[k - 1];
}

struct sentence kth_sentence_in_mth_paragraph(struct document Doc, int k, int m) {
    return Doc.data[m - 1].data[k - 1];
}

struct word kth_word_in_mth_sentence_of_nth_paragraph(struct document Doc, int k, int m, int n) {
    return Doc.data[n - 1].data[m - 1].data[k - 1];
}


